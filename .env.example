APP_NAME="RT Water Solution"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.votre-domaine.cm

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rtwater
DB_USERNAME=rtwater_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# URL du frontend (utilisée par CORS)
FRONTEND_URL=https://votre-domaine.cm

# Optionnel : paiement SEBPAY
SEBPAY_API_KEY=
SEBPAY_SECRET=
SEBPAY_ENV=production
